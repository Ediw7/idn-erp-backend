<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_setup_pelanggan_tree" model="ir.ui.view">
            <field name="name">invoicingbackend.pelanggan.tree</field>
            <field name="model">invoicingbackend.pelanggan</field>
            <field name="arch" type="xml">
                <tree string="Pelanggan">
                    <field name="kode"/>
                    <field name="nama"/>
                    <field name="npwp"/>
                    <field name="telepon"/>
                    <field name="contact_person"/>
                    <field name="pembayaran_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_setup_pelanggan_form" model="ir.ui.view">
            <field name="name">invoicingbackend.pelanggan.form</field>
            <field name="model">invoicingbackend.pelanggan</field>
            <field name="arch" type="xml">
                <form string="Pelanggan">
                    <sheet>
                        <group>
                            <group>
                                <field name="kode"/>
                                <field name="is_ekspor"/>
                                <field name="nama"/>
                                <field name="alamat"/>
                                <field name="telepon"/>
                                <field name="fax"/>
                                <field name="alamat_kirim"/>
                                <field name="telepon_kirim"/>
                                <field name="fax_kirim"/>
                            </group>
                            <group>
                                <field name="nama_wp"/>
                                <field name="npwp"/>
                                <field name="nik"/>
                                <field name="alamat_wp"/>
                                <field name="jenis_transaksi"/>
                                <field name="ket_tambahan"/>
                                <field name="email"/>
                                <field name="contact_person"/>
                                <field name="no_hp"/>
                                <field name="jabatan"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="pembayaran_id"/>
                                <field name="tingkat_harga"/>
                                <field name="diskon"/>
                            </group>
                            <group>
                                <field name="perk_piutang_id"/>
                                <field name="keterangan"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_setup_pelanggan" model="ir.actions.act_window">
            <field name="name">Setup Pelanggan</field>
            <field name="res_model">invoicingbackend.pelanggan</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Buat Pelanggan Baru
              </p>
            </field>
        </record>

        <!-- Menus -->
        <!-- Main Menu for the App -->
        <menuitem id="menu_invoicingbackend_root" name="EDI Accounting Setup" sequence="10"/>
        
        <!-- Sub Menu -->
        <menuitem id="menu_setup_pelanggan" name="Pelanggan" parent="menu_invoicingbackend_root" action="action_setup_pelanggan" sequence="10"/>

    </data>
</odoo>
